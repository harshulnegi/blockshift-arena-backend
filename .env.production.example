NODE_ENV=production

# Public HTTPS API host. DNS must point this domain to the server before Caddy can issue TLS.
DOMAIN=api.blockshiftarena.example
PUBLIC_BASE_URL=https://api.blockshiftarena.example
CLIENT_ORIGIN=*

# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_128_hex_chars

# The Google Web OAuth client ID used by Android Google Sign-In.
GOOGLE_WEB_CLIENT_ID=replace_with_google_web_client_id.apps.googleusercontent.com

# Postgres container credentials. Use strong unique production values.
POSTGRES_DB=blockshift
POSTGRES_USER=blockshift
POSTGRES_PASSWORD=replace_with_strong_database_password

# Dev bypasses must stay disabled in production.
ALLOW_DEV_GOOGLE_AUTH=false
EXPOSE_DEV_OTP=false

# Email OTP login. Prefer Brevo API in production; SMTP is kept as fallback.
BREVO_API_KEY=replace_with_brevo_api_key
BREVO_API_TIMEOUT_MS=15000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_smtp_username
SMTP_PASS=replace_with_smtp_password
SMTP_FROM="BlockShift Arena <no-reply@blockshiftarena.example>"
SMTP_CONNECTION_TIMEOUT_MS=15000
SMTP_GREETING_TIMEOUT_MS=15000
SMTP_SOCKET_TIMEOUT_MS=20000

# WebRTC P2P relay fallback for cellular networks.
# Render web services cannot host UDP TURN directly; use a TURN provider or a tiny coturn VPS.
ICE_STUN_URLS=stun:stun.l.google.com:19302,stun:global.stun.twilio.com:3478
TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
TURN_USERNAME=blockshift
TURN_CREDENTIAL=replace_with_turn_password
# Or use coturn REST credentials instead of TURN_USERNAME/TURN_CREDENTIAL:
TURN_STATIC_AUTH_SECRET=
TURN_TTL_SECONDS=3600

# Free-tier load controls. Active moves stay in Redis/memory and Postgres is updated at match end.
ACTIVE_MATCH_TTL_SECONDS=21600
ACTIVE_MATCH_CACHE_FLUSH_MS=750
SPECTATOR_STATE_INTERVAL_MS=1200
MESH_RECEIPT_WINDOW=32
MATCHMAKER_REDIS_ENABLED=false
SOCKET_REDIS_ADAPTER_ENABLED=false
LEADERBOARD_CACHE_MS=5000
