NODE_ENV=development
PORT=8080
CLIENT_ORIGIN=http://localhost:3000
JWT_SECRET=replace_with_64_random_chars
DATABASE_URL=postgres://blockshift:blockshift@postgres:5432/blockshift
REDIS_URL=redis://redis:6379
PUBLIC_BASE_URL=http://localhost:8080
GOOGLE_WEB_CLIENT_ID=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# WebRTC P2P connectivity. STUN works for many networks; TURN is the cellular/NAT fallback.
# Comma-separate multiple URLs. Example:
# ICE_STUN_URLS=stun:stun.l.google.com:19302,stun:global.stun.twilio.com:3478
# TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
# TURN_USERNAME=blockshift
# TURN_CREDENTIAL=replace_with_turn_password
# Prefer TURN_STATIC_AUTH_SECRET when using coturn REST API credentials.
ICE_STUN_URLS=
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
TURN_STATIC_AUTH_SECRET=
TURN_TTL_SECONDS=3600
# Temporary verification mode: forces WebRTC to use TURN relay candidates only.
# Keep false for normal production because direct/STUN P2P is faster and cheaper.
P2P_RELAY_ONLY=false

# Free-tier load controls. Active moves are cached in Redis/memory and persisted when a match ends.
ACTIVE_MATCH_TTL_SECONDS=21600
ACTIVE_MATCH_CACHE_FLUSH_MS=750
SPECTATOR_STATE_INTERVAL_MS=1200
MESH_RECEIPT_WINDOW=32
MATCHMAKER_REDIS_ENABLED=false
SOCKET_REDIS_ADAPTER_ENABLED=false
LEADERBOARD_CACHE_MS=5000
